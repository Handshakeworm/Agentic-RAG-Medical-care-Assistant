# syntax=docker/dockerfile:1.6
#
# api 容器镜像(DEV_SPEC §1.3.3 + §8.4 J0)。
#
# 单进程容器,捆绑 FastAPI + Agent + RAG 检索 + Embedding/Reranker 加载点。
# Embedding/Reranker 模型文件通过 docker-compose volume **只读挂载**,
# 不进镜像(模型 ~10GB,镜像里塞不合理)。
#
# 镜像策略:
# - 基础: `ghcr.io/astral-sh/uv:python3.12-bookworm-slim` — 自带 uv + Python 3.12
# - 单 stage:uv sync 直接装到 /app/.venv,简单可读
# - layer cache 友好:依赖装在前(pyproject.toml + uv.lock 改才触发重装),
#   代码 COPY 在后(改代码不重装包)
# - GPU runtime:容器自身不带 CUDA libs,**靠 PyTorch wheel 自带 + 宿主 NVIDIA 驱动**
#   (通过 docker-compose deploy.resources 挂 GPU 设备 + nvidia-container-toolkit)

FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /app

# 系统依赖:
# - curl: docker healthcheck 探 /healthz 用
# - libpq5: psycopg 运行时(binary wheel 已带,但保留 ldd 找不到时兜底)
# - libgomp1: PyTorch 用的 OpenMP runtime(slim 镜像默认无,缺会启动失败)
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        libpq5 \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# 安装依赖 — 仅复制清单,代码改动不会让这层失效
COPY pyproject.toml uv.lock /app/

# UV 行为优化:
# - UV_LINK_MODE=copy: 不用硬链接(docker layer 间硬链接会失效)
# - UV_COMPILE_BYTECODE=1: 提前编译 .pyc,首次 import 快一点
# - UV_PYTHON_DOWNLOADS=never: 镜像已有 Python,禁止 uv 自动下别的版本
ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never

# --no-install-project: 这一步只装第三方依赖,项目自身后面再装
# --no-dev: 不要 dev 依赖(本项目无 [tool.uv].dev-dependencies,但稳妥起见加)
# --mount=type=cache: uv 包缓存挂载,层不会带这缓存,镜像小;rebuild 也快
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --no-dev

# 复制项目代码 — 改 src/config 只触发这层及后面的层重建
COPY src/ /app/src/
COPY config/ /app/config/

# 安装项目本身(hatchling editable),这步快(只装 src/ 包)
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev

# .venv 二进制路径加进 PATH,后面命令可直接 uvicorn / python
ENV PATH="/app/.venv/bin:$PATH"

# 端到端日志走 stdout(被 docker json-file driver 捕获 → promtail → loki)
# uvicorn 原生写 stdout,configure_logging 在 create_app 启动时把 root logger
# 也指向 stdout(spec §5.2.1.1 / H4)
EXPOSE 8000

# uvicorn 单进程(MVP 单副本);workers=1 避免重复加载 Embedding/Reranker(显存)
# --proxy-headers + --forwarded-allow-ips=*: 让 nginx X-Forwarded-* 头被识别,
# G3 限流的 client.host 才是真客户端 IP(spec G7 nginx.conf 注释)
CMD ["uvicorn", "src.api.app:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--workers", "1", \
     "--proxy-headers", \
     "--forwarded-allow-ips", "*"]
