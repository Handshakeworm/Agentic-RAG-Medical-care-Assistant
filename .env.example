# ─────────────────────────────────────────────
# 一、数据库连接
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_rag
POSTGRES_USER= admin
POSTGRES_PASSWORD= admin123

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=medical_rag

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CONFIG_CACHE_TTL=60       # 配置缓存 TTL（秒）
REDIS_RAG_CACHE_TTL=3600        # RAG 响应缓存 TTL（秒）


# ─────────────────────────────────────────────
# 二、模型本地路径
# ─────────────────────────────────────────────

# BGE-M3 Embedding 模型（CPU 推理，HuggingFace 格式目录）
BGE_M3_MODEL_PATH=/data/embedding-model/BAAI--bge-m3

# BGE-Reranker-v2-m3 精排模型（CPU 推理）
RERANKER_MODEL_PATH=/data/reranker-model/BAAI--bge-reranker-v2-m3

# LLM 推理后端（llama.cpp server 或 vLLM 的 OpenAI-compatible endpoint）
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL_PATH=/data/LLMs/Qwen3.5/Qwen3.5-35B-A3B/Qwen3.5-35B-A3B-Q4_K_M/Qwen3.5-35B-A3B-Q4_K_M.gguf
# LLM_MODEL_PATH=/path/to/Qwen3-14B-AWQ       # 备选 14B（HuggingFace snapshot 目录）
# LLM_MODEL_PATH=/path/to/Qwen3.5-9B-AWQ-4bit # 备选 9B


# ─────────────────────────────────────────────
# 三、数据文件路径
# ─────────────────────────────────────────────

# 原始 PDF 教材/指南目录（对应 data/raw_pdf/）
PDF_INPUT_DIR=/data/medical-resources/raw-pdf

# MinerU 解析产物输出目录（对应 data/mineru_output/）
MINERU_OUTPUT_DIR=/data/medical-resources/mineru-output


# ─────────────────────────────────────────────
# 四、JWT 与 API 安全
# ─────────────────────────────────────────────

JWT_SECRET_KEY=02abc71f9c15e724a31f49cd7a9fa7d6ce46659821e2b28044b818fa0933ba79
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# API 限流
RATE_LIMIT_PER_MINUTE=30


# ─────────────────────────────────────────────
# 五、FastAPI 服务
# ─────────────────────────────────────────────

API_HOST=0.0.0.0
API_PORT=8000
ENV=development     # development / production


# ─────────────────────────────────────────────
# 六、监控（Prometheus / Grafana / Loki）
# ─────────────────────────────────────────────

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3100


# ─────────────────────────────────────────────
# 七、RAG 超参（有默认值，按需覆盖）
# ─────────────────────────────────────────────

# 检索参数
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_RERANK_TOP_K=5
RERANKER_TIMEOUT_SECONDS=5

# Chunking 参数
CHUNK_SIZE=512
CHUNK_OVERLAP=64