# ─────────────────────────────────────────────
# 一、数据库连接
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_rag
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CONFIG_CACHE_TTL=60       # 配置缓存 TTL（秒）
REDIS_RAG_CACHE_TTL=3600        # RAG 响应缓存 TTL（秒）


# ─────────────────────────────────────────────
# 二、模型路径与推理后端
# ─────────────────────────────────────────────

# Qwen3-Embedding-8B 模型（HuggingFace 格式目录，BF16 权重；运行时是否量化由 EMBEDDING_DTYPE 控制）
EMBEDDING_MODEL_PATH=/data/embedding-model/Qwen--Qwen3-Embedding-8B
EMBEDDING_DEVICE=cuda                          # cuda / cpu
EMBEDDING_DTYPE=int8                           # bf16 / int8（int8 走 bitsandbytes 运行时 8bit 量化，16GB 卡必需）

# BGE-Reranker-v2-minicpm-layerwise 精排模型（GPU 推理，与 Embedding 共享显卡）
RERANKER_MODEL_PATH=/data/reranker-model/BAAI--bge-reranker-v2-minicpm-layerwise
RERANKER_DEVICE=cuda                           # cuda / cpu
RERANKER_CUTOFF_LAYER=28                       # layerwise early-exit 层（全 40 层，28 为质量/速度均衡点）

# LLM 推理后端（云端 API，OpenAI-compatible endpoint）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 阿里云 DashScope
# LLM_BASE_URL=https://api.deepseek.com/v1                       # DeepSeek
LLM_API_KEY=sk-xxx                             # 云端 API 密钥
LLM_MODEL_NAME=qwen-max                        # 云端模型名称（qwen-max / qwen-plus）


# ─────────────────────────────────────────────
# 三、数据文件路径
# ─────────────────────────────────────────────

# 原始 PDF 教材/指南目录（对应 data/raw_pdf/）
PDF_INPUT_DIR=/data/medical-resources/raw-pdf

# MinerU 解析产物输出目录（对应 data/mineru_output/）
MINERU_OUTPUT_DIR=/data/medical-resources/mineru-output


# ─────────────────────────────────────────────
# 四、JWT 与 API 安全
# ─────────────────────────────────────────────

JWT_SECRET_KEY=02abc71f9c15e724a31f49cd7a9fa7d6ce46659821e2b28044b818fa0933ba79
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# API 限流
RATE_LIMIT_PER_MINUTE=30


# ─────────────────────────────────────────────
# 五、FastAPI 服务
# ─────────────────────────────────────────────

API_HOST=0.0.0.0
API_PORT=8000
ENV=development     # development / production


# ─────────────────────────────────────────────
# 六、监控（Prometheus / Grafana / Loki）
# ─────────────────────────────────────────────

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3100


# ─────────────────────────────────────────────
# 七、RAG 超参（有默认值，按需覆盖）
# ─────────────────────────────────────────────

# 检索参数
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_RERANK_TOP_K=5
RERANKER_TIMEOUT_SECONDS=5

# Chunking 参数
CHUNK_SIZE=512
CHUNK_OVERLAP=64